{
  "name": "tileserver-rs",
  "version": "0.0.0",
  "private": true,
  "description": "Tileserver for serving vector maps from data source(s)",
  "workspaces": {
    "packages": [
      "apps/*",
      "!apps/docs"
    ],
    "catalogs": {
      "default": {
        "vue": "^3.5.32",
        "vue-tsc": "^3.2.6",
        "typescript": "^6.0.2",
        "oxlint": "^1.59.0",
        "oxfmt": "^0.44.0",
        "nuxt": "^4.4.2",
        "maplibre-gl": "^5.22.0",
        "@nuxtjs/color-mode": "^4.0.0",
        "@nuxt/fonts": "^0.14.0",
        "@vueuse/core": "^14.2.1",
        "@vueuse/nuxt": "^14.2.1",
        "motion-v": "^2.2.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-vue-next": "^1.0.0",
        "radix-vue": "^1.9.17",
        "reka-ui": "^2.9.4",
        "tailwind-merge": "^3.5.0",
        "tailwindcss-animate": "^1.0.7",
        "tw-animate-css": "^1.4.0",
        "@nuxt/eslint": "^1.15.2",
        "@nuxt/eslint-config": "^1.15.2",
        "@tailwindcss/postcss": "^4.2.2",
        "@types/node": "^25.5.2",
        "eslint": "^10.2.0",
        "eslint-plugin-better-tailwindcss": "^4.3.2",
        "eslint-plugin-oxlint": "^1.58.0",
        "shadcn-nuxt": "^2.5.3",
        "tailwindcss": "^4.2.2",
        "vite": "^8.0.5"
      },
      "client": {
        "@deck.gl/aggregation-layers": "^9.2.11",
        "@deck.gl/core": "^9.2.11",
        "@deck.gl/geo-layers": "^9.2.11",
        "@deck.gl/layers": "^9.2.11",
        "@deck.gl/mapbox": "^9.2.11",
        "@deck.gl/mesh-layers": "^9.2.11",
        "@geoql/v-maplibre": "^1.7.1",
        "@luma.gl/engine": "~9.2.6",
        "maplibre-gl-inspect": "^0.0.8",
        "@maplibre/mlt": "^1.1.8",
        "@tanstack/query-db-collection": "^1.0.35",
        "@tanstack/vue-db": "^0.0.115",
        "@tanstack/vue-query": "^5.96.2",
        "@tanstack/ai": "^0.10.0",
        "@tanstack/ai-vue": "^0.6.12",
        "@mlc-ai/web-llm": "^0.2.82",
        "markstream-vue": "^0.0.11",
        "zod": "^4.3.6",
        "@tmcw/togeojson": "^7.1.2",
        "destr": "^2.0.5",
        "nuxt-workers": "^0.1.0",
        "papaparse": "^5.5.3",
        "pmtiles": "^4.4.0",
        "shpjs": "^6.2.0",
        "@types/geojson": "^7946.0.16",
        "@types/papaparse": "^5.5.2",
        "@types/shpjs": "^3.4.7"
      },
      "marketing": {
        "@nuxtjs/plausible": "^3.0.2",
        "ogl": "^1.0.11",
        "wrangler": "^4.81.0"
      }
    }
  },
  "scripts": {
    "dev:client": "bun run --filter @tileserver-rs/client dev",
    "dev:docs": "cd apps/docs && bun run dev",
    "dev:marketing": "cd apps/marketing && bun run dev",
    "build:client": "bun run --filter @tileserver-rs/client build",
    "build:docs": "cd apps/docs && bun run build",
    "build:marketing": "cd apps/marketing && bun run build",
    "lint": "bun run --filter @tileserver-rs/client lint:fix",
    "format": "bun run --filter @tileserver-rs/client format",
    "update:deps": "bunx taze -I",
    "prepare": "is-ci || husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "catalog:default",
    "oxlint": "catalog:default",
    "typescript": "catalog:default"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinayakkulkarni/tileserver-rs.git"
  },
  "keywords": [
    "tileserver",
    "pmtiles",
    "mbtiles",
    "gis",
    "vector-tiles"
  ],
  "author": {
    "name": "Vinayak Kulkarni",
    "email": "inbox.vinayak@gmail.com",
    "url": "https://vinayakkulkarni.dev"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vinayakkulkarni/tileserver-rs/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "homepage": "https://tileserver.app"
}