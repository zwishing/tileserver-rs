{
  "name": "tileserver-rs",
  "version": "0.0.0",
  "private": true,
  "description": "Tileserver for serving vector maps from data source(s)",
  "packageManager": "pnpm@11.0.0-rc.5",
  "scripts": {
    "dev:client": "pnpm --filter @tileserver-rs/client run dev",
    "dev:docs": "pnpm --filter @tileserver-rs/docs run dev",
    "dev:marketing": "pnpm --filter @tileserver-rs/marketing run dev",
    "build:client": "pnpm --filter @tileserver-rs/client run build",
    "build:docs": "pnpm --filter @tileserver-rs/docs run build",
    "build:marketing": "pnpm --filter @tileserver-rs/marketing run build",
    "lint": "pnpm --filter @tileserver-rs/client run lint:fix",
    "format": "pnpm --filter @tileserver-rs/client run format",
    "update:deps": "pnpm dlx taze -I",
    "prepare": "is-ci || husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "catalog:default",
    "oxlint": "catalog:default",
    "typescript": "catalog:default"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinayakkulkarni/tileserver-rs.git"
  },
  "keywords": [
    "tileserver",
    "pmtiles",
    "mbtiles",
    "gis",
    "vector-tiles"
  ],
  "author": {
    "name": "Vinayak Kulkarni",
    "email": "inbox.vinayak@gmail.com",
    "url": "https://vinayakkulkarni.dev"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vinayakkulkarni/tileserver-rs/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "homepage": "https://tileserver.app"
}
