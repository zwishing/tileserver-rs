# Git
.git
.gitignore

# Build outputs
target/
.output/
.nuxt/
dist/

# Dependencies
node_modules/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log

# Local config
.env
.env.*
!.env.example

# Documentation builds
apps/docs/.output/
apps/docs/.nuxt/

# Test data — exclude bulk tile/font/raster assets but keep config files
# that the Dockerfile's `COPY data/configs/example.toml ./config.toml`
# step needs at build time. Without the allowlist below, buildx fails
# mid-build with `"/data/configs/example.toml": not found`.
data/
!data/configs/
*.pmtiles
*.mbtiles

# OS files
.DS_Store
Thumbs.db
